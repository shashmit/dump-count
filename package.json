{
  "name": "dumcont",
  "packageManager": "bun@1.3.10",
  "private": true,
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "check:api": "bun run --cwd apps/api check",
    "typecheck:api": "bun run --cwd apps/api typecheck",
    "dev:mobile": "npm --prefix apps/mobile run dev",
    "typecheck:mobile": "npm --prefix apps/mobile run typecheck"
  },
  "workspaces": [
    "apps/api",
    "packages/*"
  ]
}
