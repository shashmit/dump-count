{
  "expo": {
    "name": "dumcont",
    "slug": "dumcont",
    "scheme": "dumcont",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-web-browser"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shashmit.dumcont"
    },
    "android": {
      "package": "com.shashmit.dumcont"
    }
  }
}
